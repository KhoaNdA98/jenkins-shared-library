@Library('pipeline-library') _

// Pipeline for CoreWeb-v2 (Dify Studio) - DEV environment
// Migrated from old declarative pipeline to shared library

buildAndDeploy(
    // === REQUIRED PARAMETERS ===
    
    // Environment
    environment: 'dev',
    
    // Application name
    appName: 'coreweb-v2',
    
    // Git repository
    repo: 'https://github.com/clickaivn/clickai-dify.git',
    branch: 'feat/login_wrapper',
    
    // Git credentials
    credentialsId: 'github-pat',
    
    // Docker registry - REQUIRED
    registry: 'localhost:5000',
    
    // Kubernetes config path - REQUIRED
    kubeconfigPath: '/var/jenkins_home/.kube/config',
    
    // === OPTIONAL PARAMETERS ===
    
    // Docker build configuration
    dockerfile: './web/Dockerfile',
    buildContext: './web',
    platform: 'linux/amd64',
    
    // Build arguments
    buildArgs: [
        NEXT_PUBLIC_BASE_PATH: '/studio'
    ],
    
    // Create .env file for web app
    envFile: true,
    envFilePath: './web/.env',
    envContent: '''
PORT=3001
NEXT_PUBLIC_ENDPOINT_AUTH=/auth/api/
NEXT_PUBLIC_DEPLOY_ENV=PRODUCTION
NEXT_PUBLIC_API_PREFIX=/difybe/api
NEXT_PUBLIC_BASE_PATH=/studio
NEXT_PUBLIC_WEB_PREFIX=http://100.115.224.47:8888
NODE_ENV=production
DEBUG=false
    ''',
    
    // Kubernetes deployment
    deployment: 'clickai-coreweb-v2',
    namespace: 'dev',
    kubeContext: 'dev',
    containerName: 'coreweb-v2',
    
    // Deployment options
    setImage: true,
    waitForRollout: true,
    rolloutTimeout: '2m',
    
    // Skip health check if not needed (removes "Post Deploy Verification" stage)
    // skipHealthCheck: true,
    
    // Cleanup
    cleanupImages: true
)
