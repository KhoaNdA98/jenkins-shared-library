@Library('pipeline-library') _

// Example pipeline for ClickAPI - DEV environment

buildAndDeploy(
    environment: 'dev',
    appName: 'clickapi',
    repo: 'https://github.com/clickaivn/click-service.git',
    branch: 'main',
    credentialsId: 'github-pat',
    
    dockerfile: './docker/Dockerfile',
    buildContext: '.',
    
    deployment: 'clickai-clickapi',
    namespace: 'dev',
    containerName: 'clickapi'
)
