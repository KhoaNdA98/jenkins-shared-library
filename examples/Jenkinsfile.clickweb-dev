@Library('pipeline-library') _

// Example pipeline for ClickWeb - DEV environment with .env file
// Copy this to your Jenkins job and customize for your environment

buildAndDeploy(
    // === REQUIRED PARAMETERS ===
    
    // Environment
    environment: 'dev',
    
    // Application name (used for image naming)
    appName: 'clickweb',
    
    // Git repository
    repo: 'https://github.com/clickaivn/webapp.git',
    branch: 'feat/new-dify',
    
    // Git credentials (Jenkins credential ID)
    credentialsId: 'github-pat',
    
    // Docker registry - REQUIRED
    // For dev: typically 'localhost:5000' for local registry
    // For prod: 'registry.example.com' or cloud registry URL
    registry: 'localhost:5000',
    
    // Kubernetes config path - REQUIRED
    // Path to kubeconfig file in Jenkins container
    kubeconfigPath: '/var/jenkins_home/.kube/config',
    
    // === OPTIONAL PARAMETERS ===
    
    // Docker build configuration
    dockerfile: './Dockerfile',
    buildContext: '.',
    
    // Create .env file before build
    envFile: true,
    envFilePath: './.env',
    envContent: '''
NEXT_PUBLIC_ENDPOINT_COMMUNITY=/community/api
NEXT_PUBLIC_ENDPOINT_ASSISTANCE=/assistant/api
NEXT_PUBLIC_ENDPOINT_AUTH=/auth/api
NEXT_PUBLIC_ENDPOINT_SERVICE=/service/api
NEXT_PUBLIC_ENDPOINT_CONVERSATION=/conversation/api
NEXT_PUBLIC_ENDPOINT_CONSOLE=/console/api
NEXT_PUBLIC_ENDPOINT_PAYMENT=/community/api/payment
NEXT_PUBLIC_ENDPOINT_CREDIT=/credit/api
NEXT_PUBLIC_ENDPOINT_CREATIVE=/creative/api
NEXT_PUBLIC_GA_ID=G-7Q55V1FHCJ
NEXT_PUBLIC_DOMAIN_TYPE=DEV
    ''',
    
    // Kubernetes deployment
    deployment: 'clickai-clickweb',
    namespace: 'dev',
    containerName: 'clickweb'
)
